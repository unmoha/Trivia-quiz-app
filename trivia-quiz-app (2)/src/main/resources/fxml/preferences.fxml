<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.trivia.controller.PreferencesController">
    <children>
        <VBox spacing="12" padding="20">
            <Label text="Quiz Preferences" style="-fx-font-size:18px; -fx-font-weight:bold;"/>
            <HBox spacing="10">
                <Label text="Number of Questions:"/>
                <Spinner fx:id="spinnerAmount" prefWidth="100"/>
            </HBox>
            <HBox spacing="10">
                <Label text="Category:"/>
                <ComboBox fx:id="comboCategory" prefWidth="300"/>
            </HBox>
            <HBox spacing="10">
                <Label text="Difficulty:"/>
                <ComboBox fx:id="comboDifficulty" prefWidth="200"/>
            </HBox>
            <HBox spacing="10">
                <Label text="Type:"/>
                <ComboBox fx:id="comboType" prefWidth="200"/>
            </HBox>
            <Region VBox.vgrow="ALWAYS"/>
            <HBox spacing="10">
                <Button text="Apply & Close" onAction="#applyAndClose" fx:id="btnApply"/>
            </HBox>
        </VBox>
    </children>
</AnchorPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.trivia.controller.QuizController">
    <children>
        <VBox spacing="12" padding="20">
            <Label fx:id="lblQuestion" wrapText="true" style="-fx-font-size:16px; -fx-font-weight:bold;"/>
            <VBox fx:id="answersBox" spacing="8"/>
            <HBox spacing="10">
                <Label fx:id="lblStatus" />
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblScore" text="Score: 0"/>
                <Button fx:id="btnNext" text="Next"/>
            </HBox>
        </VBox>
    </children>
</AnchorPane>
